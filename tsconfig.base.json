{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@nexus/protocol": ["packages/protocol/src/index.ts"],
      "@nexus/model-gateway": ["packages/model-gateway/src/index.ts"],
      "@nexus/sandbox": ["packages/sandbox/src/index.ts"],
      "@nexus/storage": ["packages/storage/src/index.ts"],
      "@nexus/tools": ["packages/tools/src/index.ts"],
      "@nexus/memory": ["packages/memory/src/index.ts"],
      "@nexus/extensions": ["packages/extensions/src/index.ts"],
      "@nexus/i18n": ["packages/i18n/src/index.ts"],
      "@nexus/bot": ["packages/bot/src/index.ts"],
      "@nexus/runtime": ["packages/runtime/src/index.ts"]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "isolatedModules": true,
    "outDir": "${configDir}/dist",
    "rootDir": "${configDir}/src",
    "tsBuildInfoFile": "${configDir}/dist/.tsbuildinfo"
  }
}
