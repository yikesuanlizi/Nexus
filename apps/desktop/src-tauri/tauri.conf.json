{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus",
  "version": "0.3.0",
  "identifier": "local.nexus.desktop",
  "build": {
    "beforeDevCommand": {
      "script": "node scripts/start-desktop.mjs",
      "cwd": "../../.."
    },
    "beforeBuildCommand": {
      "script": "npm --workspace @nexus/desktop run build:ui",
      "cwd": "../../.."
    },
    "devUrl": "http://127.0.0.1:5178",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Nexus",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local-first Agent OS",
    "longDescription": "Nexus is a local-first Agent OS for coding, tools, skills, MCP, and multi-agent workflows.",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "template": "installer.nsi"
      }
    }
  }
}
